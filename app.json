{
  "expo": {
    "name": "Electricity Billing",
    "slug": "electricity-billing",
    "scheme": "electricity-billing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icons/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 1,
      "version": "1.0.0",
      "icon": "./src/assets/icons/android/ic_launcher.png",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icons/android/ic_launcher_foreground.png",
        "backgroundImage": "./src/assets/icons/android/ic_launcher_background.png",
        "monochromeImage": "./src/assets/icons/android/ic_launcher_monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jairam.electricitybilling"
    },
    "web": {
      "favicon": "./src/assets/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./src/assets/icons/splash-icon.png",
          "dark": {
            "image": "./src/assets/icons/splash-icon.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 200
        }
      ]
    ]
  }
}